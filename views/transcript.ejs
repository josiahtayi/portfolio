<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Academic Transcript | Josiah Tayi</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
    <style>
        .transcript-section {
            max-width: 860px;
            margin: 1.25rem auto;
        }

        .degree-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            flex-wrap: wrap;
            gap: 0.75rem;
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--border);
        }

        .degree-meta h3 {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 3px;
        }

        .degree-meta p {
            font-size: 0.875rem;
            color: var(--text-muted);
        }

        .gpa-badge {
            background: rgba(99,102,241,0.12);
            border: 1px solid rgba(99,102,241,0.3);
            color: var(--accent-light);
            padding: 0.4rem 1rem;
            border-radius: 8px;
            font-size: 0.9rem;
            font-weight: 700;
            white-space: nowrap;
        }

        .transcript-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.875rem;
        }

        .transcript-table thead th {
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--text-muted);
            font-weight: 600;
            padding: 0 0.75rem 0.6rem;
            text-align: left;
            border-bottom: 1px solid var(--border);
        }

        .transcript-table thead th:last-child,
        .transcript-table thead th:nth-last-child(2) {
            text-align: center;
        }

        .transcript-table tbody tr {
            border-bottom: 1px solid rgba(30,30,54,0.6);
            transition: background var(--ease);
        }

        .transcript-table tbody tr:last-child {
            border-bottom: none;
        }

        .transcript-table tbody tr:hover {
            background: rgba(99,102,241,0.04);
        }

        .transcript-table td {
            padding: 0.6rem 0.75rem;
            color: var(--text-secondary);
            vertical-align: middle;
        }

        .year-cell {
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.8rem;
            width: 50px;
        }

        .mark-cell {
            text-align: center;
            font-weight: 600;
            color: var(--text);
            width: 60px;
        }

        .grade-cell {
            text-align: center;
            width: 70px;
        }

        .grade-badge {
            display: inline-block;
            padding: 0.15rem 0.55rem;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.04em;
        }

        .grade-hd {
            background: rgba(34,211,238,0.12);
            border: 1px solid rgba(34,211,238,0.3);
            color: #22d3ee;
        }

        .grade-di {
            background: rgba(99,102,241,0.12);
            border: 1px solid rgba(99,102,241,0.3);
            color: var(--accent-light);
        }

        .grade-cr {
            background: rgba(251,191,36,0.1);
            border: 1px solid rgba(251,191,36,0.3);
            color: #fbbf24;
        }

        .grade-pa {
            background: rgba(100,116,139,0.12);
            border: 1px solid rgba(100,116,139,0.3);
            color: #94a3b8;
        }

        .year-group-row td {
            padding-top: 1.1rem;
        }

        details.credit-transfers {
            margin-top: 1.25rem;
        }

        details.credit-transfers summary {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            cursor: pointer;
            user-select: none;
            padding: 0.5rem 0;
            border-top: 1px solid var(--border);
            list-style: none;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        details.credit-transfers summary::before {
            content: '›';
            font-size: 1rem;
            transition: transform 0.15s ease;
            display: inline-block;
        }

        details[open].credit-transfers summary::before {
            transform: rotate(90deg);
        }

        .credit-list {
            list-style: none;
            padding: 0.75rem 0 0;
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem;
        }

        .credit-list li {
            background: var(--surface-2);
            border: 1px solid var(--border);
            color: var(--text-muted);
            font-size: 0.78rem;
            padding: 0.2rem 0.65rem;
            border-radius: 4px;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            font-size: 0.875rem;
            color: var(--text-muted);
            max-width: 860px;
            margin: 1.25rem auto 0;
            padding: 0 2rem;
            display: block;
        }

        .back-link:hover { color: var(--accent-light); }

        .institution-line {
            font-size: 0.78rem;
            color: var(--text-muted);
            text-align: right;
            margin-top: 1.25rem;
            max-width: 860px;
            margin-left: auto;
            margin-right: auto;
            padding: 0 2rem;
        }
    </style>
</head>
